{
  "name": "image-api-studio",
  "version": "1.0.0",
  "description": "A lightweight image generation studio for OpenAI-compatible APIs.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build:client": "vite build --config client/vite.config.js --configLoader native",
    "start": "node src/index.js",
    "start:legacy": "node server.js",
    "check": "node --check src/index.js",
    "test": "vitest run --configLoader native",
    "test:watch": "vitest"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "multer": "^2.1.1",
    "sharp": "^0.33.5",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^12.1.1"
  },
  "devDependencies": {
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
